<?xml version="1.0" encoding="utf-8"?>
<!--
  network_security_config.xml
  Place at: android/app/src/main/res/xml/network_security_config.xml
  (Capacitor creates this folder after `cap add android`)

  Only HTTPS is allowed. No cleartext HTTP.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
